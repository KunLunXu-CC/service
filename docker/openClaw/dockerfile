# 基础镜像: OpenClaw 官方要求 Node.js 22+
FROM node:22-bookworm-slim

# 维护者信息
LABEL maintainer="moyuanjun moyuanjun@gmai.com"

# 创建并设置工作目录
RUN mkdir -p /var/openClaw
WORKDIR /var/openClaw

# 设置挂载点
VOLUME ["/var/openClaw"]

# 规避 sharp 原生编译在部分环境下的失败（官方安装文档建议）
ENV SHARP_IGNORE_GLOBAL_LIBVIPS=1

# 使用 npm 安装 OpenClaw（官方稳定安装方式）
RUN npm install -g openclaw@latest && npm cache clean --force

# OpenClaw Gateway 默认端口
EXPOSE 18789

# 容器启动时运行 OpenClaw Gateway
CMD ["openclaw", "gateway", "--port", "18789"]
